# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit secrets.

# ============================================
# Supabase
# ============================================
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Razorpay
# ============================================
# Get these from Razorpay dashboard: Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ============================================
# MSG91 (Phone OTP)
# ============================================
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-otp-template-id
MSG91_SENDER_ID=your-sender-id

# ============================================
# Cloudinary (Image uploads)
# ============================================
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# Auth session signing
# ============================================
# Pepper used to derive deterministic Supabase Auth passwords from phone numbers.
# Must never change after first user signs up — changing it breaks all existing sessions.
# Generate: openssl rand -hex 32
SUPABASE_PHONE_PASSWORD_SECRET=your-32-char-random-secret-here

# ============================================
# App config
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=BrandName
